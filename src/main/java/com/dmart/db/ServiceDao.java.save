    public static String getMobile(String email, boolean isProdDB) {

        ArrayList<HashMap<String, String>> result;
        String mobile = "";

        try {

            System.out.println("GET MOBILE BY EMAIL : " + email);

            result = DBUtility.RunQuery(
                    "select * from account_user where email = ?",
                    new String[]{email},
                    isProdDB
            );

            if (result != null && result.size() > 0) {

                for (int ii = 0; ii < result.size(); ii++) {
                    mobile = result.get(ii).get("mobile_no");
                }

                System.out.println("FOUND MOBILE : " + mobile);

            } else {

                System.out.println("NO MOBILE FOUND");

            }

        } catch (Exception ee) {
            System.out.println("ERROR IN getMobile()");
            ee.printStackTrace();
        }

        return mobile;
    }

